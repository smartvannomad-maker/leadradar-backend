
{
  "manifest_version": 3,
  "name": "LeadRadar Saver",
  "version": "3.1.0",
  "description": "Save LinkedIn leads to LeadRadar",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}